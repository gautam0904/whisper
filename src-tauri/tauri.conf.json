{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whisper",
  "version": "0.1.0",
  "identifier": "com.malaviyagautam.whisper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Whisper",
        "url": "index.html",
        "width": 900,
        "height": 620,
        "minWidth": 480,
        "minHeight": 320,
        "transparent": true,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true,
        "focus": true,
        "resizable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Whisper uses speech recognition to convert your voice into text for the AI chat box.",
        "NSMicrophoneUsageDescription": "Whisper needs microphone access to transcribe your voice into the AI chat box."
      }
    }
  }
}